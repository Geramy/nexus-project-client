<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- No keychain-access-groups / data-protection keychain entitlement: it is
	     fragile for Developer-ID apps distributed outside the App Store (can cause
	     launch rejection) and ad-hoc/debug builds can't carry it. Account
	     credentials use the legacy file-based keychain instead (see
	     nexus_account_store.dart), matching the app's other secure stores. -->
</dict>
</plist>
